# Generated reports and logs
artifacts/reports/*.json
artifacts/reports/*.tmp
artifacts/reports/*.log
!artifacts/reports/.gitkeep

# Notebook runtime outputs/checkpoints
notebooks/**/*.nbconvert.*

# Optional local datasets and archives
data/raw/*.zip
data/raw/*.tar
data/raw/*.gz
data/processed/*.jsonl

# Keep secrets/tokens local only
*.pem
*.key
*.p12
*.pfx
