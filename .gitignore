__pycache__/
*.pyc
.venv/
.env
.ipynb_checkpoints/

# Python/tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/

# OS/editor noise
.DS_Store
Thumbs.db

# Local model and training artifacts (large/binary)
artifacts/models/*
